@page
@model PromptBank.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="row justify-content-center">
    <div class="col-12" style="max-width:440px;">

        <div class="card shadow-sm pb-card-form">
            <div class="card-header py-3 pb-card-header">
                <h1 class="h4 fw-bold mb-0 pb-primary-text">
                    <i class="bi bi-person-plus me-2"></i>Register
                </h1>
            </div>
            <div class="card-body p-4">
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="Input.Username" class="form-label fw-semibold">
                            Username <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Input.Username" class="form-control" autocomplete="username" autofocus />
                        <span asp-validation-for="Input.Username" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Password" class="form-label fw-semibold">
                            Password <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Input.Password" class="form-control" autocomplete="new-password" />
                        <span asp-validation-for="Input.Password" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Input.ConfirmPassword" class="form-label fw-semibold">
                            Confirm Password <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" />
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-person-plus me-1"></i>Create Account
                    </button>
                </form>

                <hr class="my-3" />
                <p class="text-center mb-0 small">
                    Already have an account?
                    <a asp-page="/Account/Login" class="pb-link-primary">Login here</a>
                </p>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
