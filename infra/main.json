{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.42.1.51946",
      "templateHash": "8069002699563364313"
    }
  },
  "parameters": {
    "environment": {
      "type": "string",
      "allowedValues": [
        "dev",
        "prod"
      ],
      "metadata": {
        "description": "Target deployment environment. Drives resource naming and SKU selection."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "uksouth",
      "metadata": {
        "description": "Azure region for all resources. Defaults to uksouth."
      }
    }
  },
  "variables": {
    "appPlanSku": "[if(equals(parameters('environment'), 'prod'), 'B2', 'B1')]",
    "aspnetEnvironment": "[if(equals(parameters('environment'), 'prod'), 'Production', 'Development')]",
    "resourceNames": {
      "appServicePlan": "[format('asp-promptbank-{0}', parameters('environment'))]",
      "appService": "[format('app-promptbank-{0}', parameters('environment'))]"
    }
  },
  "resources": [
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "appServicePlanDeploy",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
          "name": {
            "value": "[variables('resourceNames').appServicePlan]"
          },
          "location": {
            "value": "[parameters('location')]"
          },
          "sku": {
            "value": "[variables('appPlanSku')]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.42.1.51946",
              "templateHash": "3364668567809798005"
            }
          },
          "parameters": {
            "name": {
              "type": "string",
              "metadata": {
                "description": "Name of the App Service Plan."
              }
            },
            "location": {
              "type": "string",
              "metadata": {
                "description": "Azure region for the App Service Plan."
              }
            },
            "sku": {
              "type": "string",
              "metadata": {
                "description": "SKU name for the plan (e.g. B1, B2)."
              }
            }
          },
          "resources": [
            {
              "type": "Microsoft.Web/serverfarms",
              "apiVersion": "2023-01-01",
              "name": "[parameters('name')]",
              "location": "[parameters('location')]",
              "kind": "linux",
              "sku": {
                "name": "[parameters('sku')]"
              },
              "properties": {
                "reserved": true
              }
            }
          ],
          "outputs": {
            "id": {
              "type": "string",
              "metadata": {
                "description": "Resource ID of the App Service Plan."
              },
              "value": "[resourceId('Microsoft.Web/serverfarms', parameters('name'))]"
            },
            "name": {
              "type": "string",
              "metadata": {
                "description": "Name of the provisioned App Service Plan."
              },
              "value": "[parameters('name')]"
            }
          }
        }
      }
    },
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "appServiceDeploy",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
          "name": {
            "value": "[variables('resourceNames').appService]"
          },
          "location": {
            "value": "[parameters('location')]"
          },
          "appServicePlanId": {
            "value": "[reference(resourceId('Microsoft.Resources/deployments', 'appServicePlanDeploy'), '2025-04-01').outputs.id.value]"
          },
          "aspnetEnvironment": {
            "value": "[variables('aspnetEnvironment')]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.42.1.51946",
              "templateHash": "17722302222177549437"
            }
          },
          "parameters": {
            "name": {
              "type": "string",
              "metadata": {
                "description": "Name of the Web App."
              }
            },
            "location": {
              "type": "string",
              "metadata": {
                "description": "Azure region for the Web App."
              }
            },
            "appServicePlanId": {
              "type": "string",
              "metadata": {
                "description": "Resource ID of the App Service Plan."
              }
            },
            "aspnetEnvironment": {
              "type": "string",
              "metadata": {
                "description": "Value for the ASPNETCORE_ENVIRONMENT app setting (Development or Production)."
              }
            }
          },
          "variables": {
            "sqliteConnectionString": "Data Source=/home/data/promptbank.db"
          },
          "resources": [
            {
              "type": "Microsoft.Web/sites",
              "apiVersion": "2023-01-01",
              "name": "[parameters('name')]",
              "location": "[parameters('location')]",
              "properties": {
                "serverFarmId": "[parameters('appServicePlanId')]",
                "httpsOnly": true,
                "siteConfig": {
                  "linuxFxVersion": "DOTNETCORE|10.0",
                  "minTlsVersion": "1.2",
                  "appSettings": [
                    {
                      "name": "ASPNETCORE_ENVIRONMENT",
                      "value": "[parameters('aspnetEnvironment')]"
                    },
                    {
                      "name": "ConnectionStrings__DefaultConnection",
                      "value": "[variables('sqliteConnectionString')]"
                    },
                    {
                      "name": "WEBSITE_RUN_FROM_PACKAGE",
                      "value": "1"
                    }
                  ]
                }
              }
            }
          ],
          "outputs": {
            "name": {
              "type": "string",
              "metadata": {
                "description": "Name of the provisioned Web App."
              },
              "value": "[parameters('name')]"
            },
            "defaultHostName": {
              "type": "string",
              "metadata": {
                "description": "Default hostname of the Web App (e.g. app-promptbank-dev.azurewebsites.net)."
              },
              "value": "[reference(resourceId('Microsoft.Web/sites', parameters('name')), '2023-01-01').defaultHostName]"
            }
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Resources/deployments', 'appServicePlanDeploy')]"
      ]
    }
  ],
  "outputs": {
    "appServiceName": {
      "type": "string",
      "metadata": {
        "description": "Name of the Web App — used by the app deployment workflow for az webapp deploy."
      },
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'appServiceDeploy'), '2025-04-01').outputs.name.value]"
    },
    "appServiceUrl": {
      "type": "string",
      "metadata": {
        "description": "Default hostname of the Web App."
      },
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'appServiceDeploy'), '2025-04-01').outputs.defaultHostName.value]"
    }
  }
}